<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.FlowPane?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<StackPane fx:id="rootPane" prefHeight="800.0" prefWidth="1280.0" stylesheets="@style.css" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="uni.palestra.GymController">
    <children>
        <BorderPane>
            <left>
                <VBox prefWidth="240.0" styleClass="sidebar" BorderPane.alignment="CENTER">
                    <children>
                        <Label style="-fx-text-fill: white; -fx-font-size: 22px; -fx-font-weight: 900;" text="GYM FX">
                            <VBox.margin>
                                <Insets bottom="15.0" left="25.0" />
                            </VBox.margin>
                        </Label>
                        <Label style="-fx-text-fill: white; -fx-font-size: 15px; -fx-font-weight: 300;" text="Powered by Domenico Santagada">
                            <VBox.margin>
                                <Insets bottom="30.0" left="15.0" />
                            </VBox.margin>
                        </Label>
                        <ScrollPane fitToWidth="true" style="-fx-background: transparent; -fx-background-color: transparent;">
                            <content>
                                <VBox fx:id="categoryBox" />
                            </content>
                        </ScrollPane>
                    </children>
                    <padding>
                        <Insets top="25.0" />
                    </padding>
                </VBox>
            </left>
            <center>
                <BorderPane prefHeight="200.0" prefWidth="200.0" BorderPane.alignment="CENTER">
                    <center>
                        <ScrollPane fx:id="mainScrollPane" fitToWidth="true" styleClass="scroll-pane" BorderPane.alignment="CENTER">
                            <content>
                                <FlowPane fx:id="imageGrid" hgap="20.0" styleClass="image-grid" vgap="20.0" />
                            </content>
                        </ScrollPane>
                    </center>
                    <top>
                        <Label style="-fx-font-size: 17px; -fx-font-family: arial;" text="Click sinistro per aprire/chiudere l'immagine. Clik destro per selezionare/deselezionare l'immagine. " BorderPane.alignment="CENTER">
                            <BorderPane.margin>
                                <Insets top="20.0" />
                            </BorderPane.margin>
                        </Label>
                    </top>
                </BorderPane>
            </center>
        </BorderPane>
    </children>
</StackPane>
