<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.layout.*?>
<StackPane xmlns:fx="http://javafx.com/fxml/1" fx:id="rootPane" prefHeight="800.0"
           prefWidth="1280.0" stylesheets="@style.css"
           xmlns="http://javafx.com/javafx/17"
           fx:controller="uni.palestra.GymController">
    <children>
        <BorderPane>
            <left>
                <VBox prefWidth="240.0" styleClass="sidebar" BorderPane.alignment="CENTER">
                    <children>
                        <Label style="-fx-text-fill: white; -fx-font-size: 22px; -fx-font-weight: 900;" text="GYM APP">
                            <VBox.margin>
                                <Insets bottom="30.0" left="25.0"/>
                            </VBox.margin>
                        </Label>
                        <ScrollPane fitToWidth="true"
                                    style="-fx-background: transparent; -fx-background-color: transparent;">
                            <content>
                                <VBox fx:id="categoryBox"/>
                            </content>
                        </ScrollPane>
                    </children>
                    <padding>
                        <Insets top="25.0"/>
                    </padding>
                </VBox>
            </left>
            <center>
                <ScrollPane fitToWidth="true" styleClass="scroll-pane" BorderPane.alignment="CENTER">
                    <content>
                        <FlowPane fx:id="imageGrid" hgap="20.0" vgap="20.0" styleClass="image-grid"/>
                    </content>
                </ScrollPane>
            </center>
        </BorderPane>
    </children>
</StackPane>